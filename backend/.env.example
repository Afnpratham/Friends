# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# AI provider routing. Mock works without paid API keys.
AI_PROVIDER_DEFAULT=gemini
AI_FALLBACK_PROVIDER=mock
MAX_REPAIR_ATTEMPTS=3
MINIMUM_QUALITY_SCORE=8
MIN_STAGE_DURATION_MS=1500

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FAST_MODEL=gemini-2.5-flash
GEMINI_THINKING_BUDGET=8192

# Ollama local coding model
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:30b

# Optional hosted providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
